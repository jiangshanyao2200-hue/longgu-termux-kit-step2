system/target/

# runtime logs
logs/

# runtime backups (large, machine-local)
backups/

# runtime startboot pool (generated by installer)
startboot/

# system runtime dirs (also ignored by system/.gitignore, keep a belt-and-suspenders here)
system/log/
system/memory/

# sqlite
memory/*.sqlite
memory/*.db
memory/*.sqlite-wal
memory/*.sqlite-shm

# local ad-hoc backups
system/src/*.bak*

# local scratch
system/test_file.txt
test_patch.txt

# local backups
backup/
