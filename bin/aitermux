#!/data/data/com.termux/files/usr/bin/env bash
set -euo pipefail

ROOT_DIR="${AITERMUX_HOME:-$HOME/AItermux}"
PROJECT_DIR="$ROOT_DIR/projectying"
RUN_SCRIPT="$PROJECT_DIR/run.sh"
BOOTSTRAP_BIN="$ROOT_DIR/bin/aitermux-bootstrap"

cleanup() {
  stty sane >/dev/null 2>&1 || true
  if [[ -t 1 ]]; then
    printf '\033[0m\033[?25h\033[?1049l' >/dev/tty 2>/dev/null || true
  fi
}
trap cleanup EXIT

usage() {
  cat <<'EOF'
AITermux 启动器

用法：
  aitermux [--help] [-- <projectying args>]
  aitermux [projectying args]
EOF
}

cleanup_orphan_projectying() {
  local pid ppid
  local -a pids=()
  while read -r pid ppid _; do
    if [[ -n "${pid:-}" && -n "${ppid:-}" && "$ppid" == "1" ]]; then
      pids+=("$pid")
    fi
  done < <(
    ps -o pid=,ppid=,args= -A 2>/dev/null \
      | grep -F "$PROJECT_DIR/target/" \
      | grep -F "/projectying" \
      | grep -v grep \
      || true
  )
  if ((${#pids[@]})); then
    kill "${pids[@]}" 2>/dev/null || true
    sleep 0.05
    kill -9 "${pids[@]}" 2>/dev/null || true
  fi
}

ensure_projectying_ready() {
  if [[ -f "$RUN_SCRIPT" ]]; then
    chmod u+x "$RUN_SCRIPT" >/dev/null 2>&1 || true
  fi

  if [[ ! -x "$RUN_SCRIPT" && -x "$BOOTSTRAP_BIN" ]]; then
    "$BOOTSTRAP_BIN" --quiet --force --component projectying || true
    [[ -f "$RUN_SCRIPT" ]] && chmod u+x "$RUN_SCRIPT" >/dev/null 2>&1 || true
  fi

  if [[ ! -x "$RUN_SCRIPT" ]]; then
    echo "[aitermux] 缺少 Project 萤启动脚本：$RUN_SCRIPT" >&2
    exit 1
  fi
}

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  usage
  exit 0
fi

ensure_projectying_ready
cleanup_orphan_projectying || true

export AITERMUX_STARTED=1
cd "$PROJECT_DIR"
exec "$RUN_SCRIPT" "$@"
